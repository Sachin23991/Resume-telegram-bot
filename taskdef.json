{
  "family": "cv-analyzer-bot",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "cv-analyzer-bot",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/cv-analyzer-bot:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },

        { "name": "TELEGRAM_BOT_TOKEN", "value": "<PASTE_TELEGRAM_BOT_TOKEN>" },

        { "name": "MONGODB_URL", "value": "<PASTE_MONGODB_URL>" },
        { "name": "MONGODB_DB_NAME", "value": "<PASTE_MONGODB_DB_NAME>" },

        { "name": "OPENROUTER_KEY_1", "value": "<PASTE_OPENROUTER_KEY_1>" },
        { "name": "OPENROUTER_KEY_2", "value": "<PASTE_OPENROUTER_KEY_2>" },
        { "name": "OPENROUTER_KEY_3", "value": "<PASTE_OPENROUTER_KEY_3>" },
        { "name": "OPENROUTER_KEY_FALLBACK", "value": "<PASTE_OPENROUTER_KEY_FALLBACK>" },
        { "name": "GEMINI_API_KEY", "value": "<PASTE_GEMINI_API_KEY>" },
        { "name": "OPENAI_API_KEY", "value": "<PASTE_OPENAI_API_KEY>" },

        { "name": "APILAYER_KEY_1", "value": "<PASTE_APILAYER_KEY_1>" },
        { "name": "APILAYER_KEY_2", "value": "<PASTE_APILAYER_KEY_2>" },
        { "name": "APILAYER_KEY_3", "value": "<PASTE_APILAYER_KEY_3>" },
        { "name": "APILAYER_KEY_4", "value": "<PASTE_APILAYER_KEY_4>" },

        { "name": "AFFINDA_KEY_1", "value": "<PASTE_AFFINDA_KEY_1>" },
        { "name": "AFFINDA_KEY_2", "value": "<PASTE_AFFINDA_KEY_2>" },
        { "name": "AFFINDA_KEY_3", "value": "<PASTE_AFFINDA_KEY_3>" },
        { "name": "AFFINDA_KEY_4", "value": "<PASTE_AFFINDA_KEY_4>" },

        { "name": "RESUME_SCORE_KEY_1", "value": "<PASTE_RESUME_SCORE_KEY_1>" },
        { "name": "RESUME_SCORE_KEY_2", "value": "<PASTE_RESUME_SCORE_KEY_2>" },
        { "name": "RESUME_SCORE_KEY_3", "value": "<PASTE_RESUME_SCORE_KEY_3>" },
        { "name": "RESUME_SCORE_KEY_4", "value": "<PASTE_RESUME_SCORE_KEY_4>" },

        { "name": "USERESUME_KEY_1", "value": "<PASTE_USERESUME_KEY_1>" },
        { "name": "USERESUME_KEY_2", "value": "<PASTE_USERESUME_KEY_2>" },
        { "name": "USERESUME_KEY_3", "value": "<PASTE_USERESUME_KEY_3>" },

        { "name": "CVPARSER_KEY_1", "value": "<PASTE_CVPARSER_KEY_1>" },
        { "name": "CVPARSER_KEY_2", "value": "<PASTE_CVPARSER_KEY_2>" },
        { "name": "CVPARSER_KEY_3", "value": "<PASTE_CVPARSER_KEY_3>" },
        { "name": "CVPARSER_KEY_4", "value": "<PASTE_CVPARSER_KEY_4>" },
        { "name": "CVPARSER_API_URL", "value": "https://api.cvparser-api.com/graphql" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cv-analyzer-bot",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
